<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  ExportOptions template for SecureChat TestFlight uploads.
  Generated by scripts/generate-export-options.sh to
  apps/SecureChat/ExportOptions.plist (gitignored).

  Key settings:
    - method:                "app-store-connect" (TestFlight)
    - destination:           "export" (we want a clean .ipa, not
                             direct upload from xcodebuild)
    - signingStyle:          "automatic"  (Xcode picks the
                             distribution identity from the team)
    - teamID:                "355NB9T8RJ" (Apple Distribution
                             team for Francois Alexandre Marie
                             De Lattre; see privatechat-dev
                             apple developer account)
    - uploadSymbols:         true         (so crash reports from
                             TestFlight builds are symbolicated)
    - uploadBitcode:         false        (Apple deprecated this in
                             Xcode 14, but kept the key for compat)

  Strip the Swift symbols only if you want smaller IPAs. The
  default is to keep them so the dSYMs can be downloaded from
  App Store Connect for symbolicated crash reports.
-->
<plist version="1.0">
<dict>
    <key>destination</key>
    <string>export</string>
    <key>method</key>
    <string>app-store-connect</string>
    <key>signingStyle</key>
    <string>automatic</string>
    <key>teamID</key>
    <string>355NB9T8RJ</string>
    <key>uploadSymbols</key>
    <true/>
    <key>uploadBitcode</key>
    <false/>
    <key>stripSwiftSymbols</key>
    <true/>
    <key>compileBitcode</key>
    <false/>
    <key>embedOnDemandResourcesAssetPacksInBundle</key>
    <false/>
    <key>manageAppVersionAndBuildNumber</key>
    <true/>
    <key>applicationSigningIdentity</key>
    <string>Apple Distribution</string>
    <!--
      If you want fully automatic signing in the export step,
      leave iCloudContainerEnvironment, signingCertificate, and
      provisioningProfiles empty (Xcode auto-resolves them via
      teamID). If you want to pin to a specific profile, set
      provisioningProfiles with bundle id -> profile name.
    -->
    <key>iCloudContainerEnvironment</key>
    <string>Production</string>
    <key>provisioningProfiles</key>
    <dict>
        <key>org.francois.PrivateChat</key>
        <string>SecureChat App Store</string>
    </dict>
</dict>
</plist>
