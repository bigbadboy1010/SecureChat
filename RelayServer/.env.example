NODE_ENV=production
HOST=0.0.0.0
PORT=8080

# Production must use STORE_TYPE=file. The relay stores only encrypted packets and ACK tombstones.
STORE_TYPE=file
DATA_DIR=/data

# Generate long random values, for example:
# openssl rand -base64 48
RELAY_AUTH_TOKEN=change-this-long-random-client-token-at-least-32-chars
RELAY_ADMIN_TOKEN=change-this-long-random-admin-token-at-least-32-chars
MIN_AUTH_TOKEN_LENGTH=32

# Production hardening. Keep these enabled for public deployments behind Caddy/HTTPS.
REQUIRE_AUTH_IN_PRODUCTION=true
REQUIRE_HTTPS_IN_PRODUCTION=true
TRUST_PROXY_HEADERS=true
ENABLE_CLIENT_PURGE=false
SECURITY_AUDIT_LOG=true

# Abuse and storage controls.
MAX_PACKET_BYTES=131072
MAX_TTL_SECONDS=86400
MAX_CLOCK_SKEW_SECONDS=300
MAX_TOTAL_PACKETS=10000
MAX_PACKETS_PER_RECIPIENT=500
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW=1 minute
