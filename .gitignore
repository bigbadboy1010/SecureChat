# Build artefacts that should not be committed.

# Sprint 21: SBOM + audit output. Re-generated by CI on every push.
build/sbom/
build/audit.json
build/e2e-result.json

# Sprint 26: ephemeral test artefacts created by the smoke test.
# /tmp/securechat-smoke-site lives outside the repo, but a local
# `.env.test` is sometimes generated for debug runs. Both are
# safe to keep untracked.
RelayServer/.env.test
RelayServer/dist/

# Sprint 27: the relay's persisted peer-registry
# is created on first enrollment and lives in
# `RelayServer/data/`. This is dev-state, never
# committed: production uses `/opt/securechat/
# data/peer-registry.json` via the
# `RELAY_PEER_REGISTRY_FILE` env var.
RelayServer/data/
RelayServer/.data/

# Standard macOS / Node noise
.DS_Store
node_modules/
*.log
npm-debug.log*

# SwiftPM
.build/
.swiftpm/
Packages/
*.xcodeproj
Package.resolved

# Xcode user data
xcuserdata/
*.xcuserstate
DerivedData/

